{
  "name": "ollama",
  "displayName": "Ollama",
  "description": "Ollama language model provider for VS Code.",
  "publisher": "Ollama",
  "version": "0.0.3",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ollama/ollama-vscode.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelChatProvider:ollama-models"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "ollama-models",
        "displayName": "Ollama",
        "configuration": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "title": "Ollama URL",
              "default": "http://127.0.0.1:11434",
              "description": "Base URL for the Ollama server."
            },
            "models": {
              "type": "array",
              "title": "Models",
              "description": "Optional model names to expose from this Ollama server. When omitted, all /api/tags models are exposed.",
              "items": {
                "type": "string"
              }
            },
            "headers": {
              "type": "object",
              "title": "Headers",
              "default": {},
              "description": "Additional HTTP headers to include with Ollama model discovery and chat requests.",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    ],
    "configuration": [
      {
        "title": "Ollama",
        "properties": {
          "ollama.endpoint": {
            "type": "string",
            "default": "http://127.0.0.1:11434",
            "description": "Base URL for the Ollama server. Provider configuration from VS Code takes precedence when present."
          },
          "ollama.headers": {
            "type": "object",
            "default": {},
            "description": "Additional HTTP headers to include with Ollama model discovery and chat requests.",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "ollama.refreshModels",
        "title": "Ollama: Refresh Models"
      },
      {
        "command": "ollama.diagnoseModels",
        "title": "Ollama: Diagnose Models"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && tsc -p ./tsconfig.test.json && node --test .test-out/test/recommendations.test.js",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.120.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "ollama": "^0.6.3"
  }
}
